{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "installCommand": "bun install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "server/**",
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/daily-article",
      "schedule": "0 8 * * *"
    }
  ]
}
